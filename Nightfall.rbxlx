    Talents = {
        {
            Id            = "EchoSilence",
            Name          = "Echo Silence",
            InteractsWith = "Mana",
            Description   = "While a target is Silenced, their CDR is suppressed. For every second "
                          .. "they cannot use the locked ability, you gain +5 Mana (max 15 per cast).",
            IsUnlocked    = false,
