                            (tChar:GetAttribute("IncomingPostureDamage") or 0) + CROSSWIND_POSTURE_DMG)
                        tChar:SetAttribute("IncomingPostureDamageSource", player.Name .. "_Crosswind")
                    end

                    -- Lateral impulse (push right relative to caster)
