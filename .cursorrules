{
  "rules": [
    {
      "name": "No Code Without Issue",
      "pattern": "^(?!.*#\\d+)",
      "message": "No code without a GitHub issue reference. Every commit must reference an issue."
    },
    {
      "name": "Session Log Must Be Updated",
      "pattern": "(?i)\\b(update|change|modify)\\b.*\\bdocs/session-log.md\\b",
      "message": "After every task, update docs/session-log.md with completed work, new types created, and pending technical debt."
    },
    {
      "name": "Strict Typing Required",
      "pattern": "^(?!.*--!strict)",
      "message": "Strict typing mandatory (--!strict). Add --!strict at the top of the file."
    },
    {
      "name": "Boilerplate Header Required",
      "pattern": "^(?!.*-- Class:)",
      "message": "Every new module must include the standard documentation header (Class, Description, Dependencies)."
    },
    {
      "name": "Export Type Only",
      "pattern": "(?i)\\blocal\\s+type\\b",
      "message": "Use export type for all shared types. Never use local type for shared data."
    },
    {
      "name": "Shared Types Location",
      "pattern": "(?i)\\btype\\b.*\\b(not in src/shared/types)\\b",
      "message": "All shared types must be defined in src/shared/types."
    },
    {
      "name": "No Direct Server-Client Require",
      "pattern": "require.*src/client",
      "message": "No direct cross-boundary requires. Use src/shared/network for Remote communication."
    },
    {
      "name": "No Direct Client-Server Require",
      "pattern": "require.*src/server",
      "message": "No direct cross-boundary requires. Use src/shared/network for Remote communication."
    },
    {
      "name": "No wait() Usage",
      "pattern": "wait\\(",
      "message": "Do not use wait(). Use task.wait() or signal-based provider."
    },
    {
      "name": "StateService for State Changes",
      "pattern": "(?i)playerData\\.State\\s*=\\s*",
      "message": "Use StateService for all player state changes. Never mutate state directly."
    },
    {
      "name": "Server Validates Client Actions",
      "pattern": "(?i)NetworkService:RegisterHandler",
      "message": "Server must validate all client-sent actions: existence, type, state, resources, range."
    },
    {
      "name": "Functions Under 50 Lines",
      "pattern": "(?s)function\\s+\\w+\\(.*\\)[^{]*{[^}]{51,}}",
      "message": "Functions over 50 lines should be split. If not possible, add a comment explaining why."
    },
    {
      "name": "No Damage Calculation on Client",
      "pattern": "(?i)damage\\s*=.*client",
      "message": "Damage is never calculated by the client. Server only."
    },
    {
      "name": "No VFX Implementation",
      "pattern": "(?i)VFX_Function\\s*=\\s*function",
      "message": "VFX functions must be empty stubs with a comment describing the intended effect."
    },
    {
      "name": "No Communion Ability Implementation",
      "pattern": "(?i)Communion",
      "message": "Communion abilities must be stubs only. No implementation."
    }
  ]
}

