{
  "rules": [
    {
      "name": "Strict Typing Mandatory",
      "pattern": "^(?!.*--!strict)",
      "message": "Strict typing mandatory (--!strict). Add --!strict at the top of the file."
    },
    {
      "name": "Use Export Type",
      "pattern": "(?i)\\blocal\\s+type\\b",
      "message": "Use export type for all data schemas instead of local type."
    },
    {
      "name": "No Direct Cross-Talk Server to Client",
      "pattern": "require.*src/client",
      "message": "No direct cross-talk; use src/shared/network for Remote communication. Server logic should not require client modules."
    },
    {
      "name": "No Direct Cross-Talk Client to Server",
      "pattern": "require.*src/server",
      "message": "No direct cross-talk; use src/shared/network for Remote communication. Client logic should not require server modules."
    },
    {
      "name": "Dependency Injection",
      "pattern": "wait\\(",
      "message": "Do not use wait() for loading; use a signal-based provider."
    },
    {
      "name": "State Validation",
      "pattern": "(?i)\\bif\\s+State\\s*==\\s*\"(Stunned|Attacking)\"\\s+then\\s+return\\b",
      "message": "Ensure action validation: if State == \"Stunned\" then return, if State == \"Attacking\" then return."
    },
    {
      "name": "Mantra Framework",
      "pattern": "(?i)\\bmantra\\b.*\\b(BaseDamage|CastTime|Cooldown|VFX_Function)\\b",
      "message": "Mantras must contain: BaseDamage, CastTime, Cooldown, and VFX_Function."
    },
    {
      "name": "Composition over Large Classes",
      "pattern": "(?i)\\bclass\\s+Player\\b",
      "message": "Avoid large 'Player' classes. Use a Component system for attributes like Health, Mana, and Posture."
    },
    {
      "name": "Boilerplate Header",
      "pattern": "^(?!.*-- Class:)",
      "message": "Every new module must include the standard documentation header (Class, Description, Dependencies)."
    },
    {
      "name": "Session Log Update",
      "pattern": "(?i)\\b(update|change|modify)\\b.*\\bdocs/session-log.md\\b",
      "message": "After every task, UPDATE docs/session-log.md with completed work, new types created, and pending technical debt."
    },
    {
      "name": "Reference Shared Types",
      "pattern": "(?i)\\btype\\b.*\\b(not in src/shared/types)\\b",
      "message": "Always reference src/shared/types to ensure data structures remain consistent across the server/client boundary."
    }
  ]
}

